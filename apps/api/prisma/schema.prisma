// Quadrik — Prisma Schema
// Field names: camelCase (TypeScript-idiomatic), mapped to snake_case DB columns via @map().
// All table and column names in the database are English/snake_case.
// Multi-tenant: every resource is scoped to a clubId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserStatus {
  active
  inactive
  blocked
}

enum Role {
  SUPER_ADMIN
  OWNER
  MANAGER
  RECEPTIONIST
  FINANCE
  TEACHER
  ORGANIZER
  PLAYER
}

enum ClubMemberStatus {
  active
  invited
  inactive
}

enum ClubStatus {
  active
  inactive
  suspended
}

enum CourtStatus {
  active
  inactive
  maintenance
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
  no_show
}

enum PaymentStatus {
  pending
  paid
  overdue
  cancelled
  refunded
}

enum TournamentStatus {
  draft
  registration_open
  in_progress
  finished
  cancelled
}

enum Visibility {
  public
  private
}

enum MatchStatus {
  scheduled
  in_progress
  completed
  cancelled
  walkover
}

enum PlayerLevel {
  beginner
  intermediate
  advanced
}

enum Gender {
  male
  female
  mixed
}

enum TournamentFormat {
  group_knockout
  knockout
  round_robin
}

enum RankingType {
  manual
  automatic
}

enum SubscriptionStatus {
  active
  past_due
  cancelled
  trialing
}

enum NotificationChannel {
  in_app
  email
  push
  whatsapp
}

enum ClassAttendanceStatus {
  present
  absent
  justified
  makeup
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id              String     @id @default(uuid())
  name            String
  email           String     @unique
  phone           String?
  passwordHash    String     @map("password_hash")
  avatarUrl       String?    @map("avatar_url")
  status          UserStatus @default(active)
  emailVerifiedAt DateTime?  @map("email_verified_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  profile               UserProfile?
  memberships           ClubMember[]
  createdBookings       Booking[]            @relation("BookingCreator")
  cancelledBookings     Booking[]            @relation("BookingCanceller")
  bookingParticipations BookingParticipant[]
  notifications         Notification[]
  files                 File[]
  paymentsCreated       Payment[]            @relation("PaymentCreator")
  payments              Payment[]            @relation("UserPayments")
  auditLogs             AuditLog[]

  @@map("users")
}

model UserProfile {
  id             String       @id @default(uuid())
  userId         String       @unique @map("user_id")
  sportLevel     PlayerLevel? @map("sport_level")
  favoriteSports String[]     @map("favorite_sports")
  city           String?
  state          String?      @db.Char(2)
  bio            String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Club {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?
  logoUrl     String?    @map("logo_url")
  coverUrl    String?    @map("cover_url")
  phone       String?
  email       String?
  whatsapp    String?
  website     String?
  address     String?
  city        String?
  state       String?    @db.Char(2)
  country     String     @default("BR") @db.Char(2)
  zipCode     String?    @map("zip_code")
  sportTypes  String[]   @map("sport_types")
  status      ClubStatus @default(active)
  isPublic    Boolean    @default(true) @map("is_public")
  settings    Json       @default("{}")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  members       ClubMember[]
  courts        Court[]
  bookings      Booking[]
  players       Player[]
  teachers      Teacher[]
  classes       Class[]
  tournaments   Tournament[]
  rankings      Ranking[]
  payments      Payment[]
  notifications Notification[]
  auditLogs     AuditLog[]
  subscription  Subscription?
  products      Product[]

  @@map("clubs")
}

model ClubMember {
  id        String           @id @default(uuid())
  clubId    String           @map("club_id")
  userId    String           @map("user_id")
  role      Role
  status    ClubMemberStatus @default(invited)
  invitedBy String?          @map("invited_by")
  joinedAt  DateTime?        @map("joined_at")
  createdAt DateTime         @default(now()) @map("created_at")

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@map("club_members")
}

model Court {
  id             String      @id @default(uuid())
  clubId         String      @map("club_id")
  name           String
  sportType      String      @map("sport_type")
  surfaceType    String?     @map("surface_type")
  isIndoor       Boolean     @default(false) @map("is_indoor")
  playerCapacity Int         @default(4) @map("player_capacity")
  pricePerHour   Decimal     @map("price_per_hour") @db.Decimal(10, 2)
  status         CourtStatus @default(active)
  photoUrl       String?     @map("photo_url")
  sortOrder      Int         @default(0) @map("sort_order")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  club      Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  schedules CourtSchedule[]
  bookings  Booking[]
  matches   Match[]

  @@map("courts")
}

model CourtSchedule {
  id        String   @id @default(uuid())
  courtId   String   @map("court_id")
  dayOfWeek Int      @map("day_of_week")
  opensAt   String   @map("opens_at")
  closesAt  String   @map("closes_at")
  isClosed  Boolean  @default(false) @map("is_closed")
  createdAt DateTime @default(now()) @map("created_at")

  court Court @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@map("court_schedules")
}

model Booking {
  id              String        @id @default(uuid())
  clubId          String        @map("club_id")
  courtId         String        @map("court_id")
  createdById     String        @map("created_by_id")
  startTime       DateTime      @map("start_time")
  endTime         DateTime      @map("end_time")
  durationMinutes Int           @map("duration_minutes")
  status          BookingStatus @default(pending)
  price           Decimal       @db.Decimal(10, 2)
  paymentStatus   PaymentStatus @default(pending) @map("payment_status")
  paymentMethod   String?       @map("payment_method")
  notes           String?
  cancelledAt     DateTime?     @map("cancelled_at")
  cancelledById   String?       @map("cancelled_by_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  club         Club                 @relation(fields: [clubId], references: [id])
  court        Court                @relation(fields: [courtId], references: [id])
  createdBy    User                 @relation("BookingCreator", fields: [createdById], references: [id])
  cancelledBy  User?                @relation("BookingCanceller", fields: [cancelledById], references: [id])
  participants BookingParticipant[]
  payments     Payment[]

  @@index([clubId, courtId, startTime], name: "idx_bookings_club_court_start")
  @@index([createdById], name: "idx_bookings_created_by")
  @@index([status, startTime], name: "idx_bookings_status_date")
  @@map("bookings")
}

model BookingParticipant {
  id        String   @id @default(uuid())
  bookingId String   @map("booking_id")
  userId    String?  @map("user_id")
  guestName String?  @map("guest_name")
  isHost    Boolean  @default(false) @map("is_host")
  createdAt DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@map("booking_participants")
}

model Player {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  clubId        String      @map("club_id")
  level         PlayerLevel @default(beginner)
  favoriteSport String?     @map("favorite_sport")
  status        String      @default("active")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  club                    Club                     @relation(fields: [clubId], references: [id])
  rankingEntries          RankingEntry[]
  classEnrollments        ClassStudent[]
  attendances             ClassAttendance[]
  tournamentRegistrations TournamentRegistration[]
  matchParticipations     MatchParticipant[]

  @@map("players")
}

model Teacher {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  clubId         String   @map("club_id")
  sports         String[]
  commissionRate Decimal  @map("commission_rate") @db.Decimal(5, 2)
  status         String   @default("active")
  bio            String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  club    Club    @relation(fields: [clubId], references: [id])
  classes Class[]

  @@map("teachers")
}

model Class {
  id            String      @id @default(uuid())
  clubId        String      @map("club_id")
  teacherId     String      @map("teacher_id")
  courtId       String?     @map("court_id")
  name          String
  sportType     String      @map("sport_type")
  level         PlayerLevel
  maxStudents   Int         @map("max_students")
  pricePerMonth Decimal     @map("price_per_month") @db.Decimal(10, 2)
  schedule      Json
  status        String      @default("active")
  startDate     DateTime    @map("start_date") @db.Date
  endDate       DateTime?   @map("end_date") @db.Date
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  club        Club              @relation(fields: [clubId], references: [id])
  teacher     Teacher           @relation(fields: [teacherId], references: [id])
  students    ClassStudent[]
  attendances ClassAttendance[]
  payments    Payment[]

  @@map("classes")
}

model ClassStudent {
  id         String   @id @default(uuid())
  classId    String   @map("class_id")
  playerId   String   @map("player_id")
  status     String   @default("active")
  enrolledAt DateTime @map("enrolled_at") @db.Date
  createdAt  DateTime @default(now()) @map("created_at")

  class  Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])

  @@unique([classId, playerId])
  @@map("class_students")
}

model ClassAttendance {
  id        String                @id @default(uuid())
  classId   String                @map("class_id")
  playerId  String                @map("player_id")
  classDate DateTime              @map("class_date") @db.Date
  status    ClassAttendanceStatus
  notes     String?
  createdAt DateTime              @default(now()) @map("created_at")

  class  Class  @relation(fields: [classId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  @@unique([classId, playerId, classDate])
  @@map("class_attendance")
}

model Tournament {
  id                String           @id @default(uuid())
  clubId            String           @map("club_id")
  name              String
  slug              String           @unique
  description       String?
  sportType         String           @map("sport_type")
  coverUrl          String?          @map("cover_url")
  startDate         DateTime         @map("start_date") @db.Date
  endDate           DateTime         @map("end_date") @db.Date
  registrationStart DateTime         @map("registration_start") @db.Date
  registrationEnd   DateTime         @map("registration_end") @db.Date
  status            TournamentStatus @default(draft)
  visibility        Visibility       @default(public)
  requiresPayment   Boolean          @default(false) @map("requires_payment")
  regulations       String?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  club          Club                     @relation(fields: [clubId], references: [id])
  categories    TournamentCategory[]
  registrations TournamentRegistration[]
  matches       Match[]

  @@map("tournaments")
}

model TournamentCategory {
  id                String           @id @default(uuid())
  tournamentId      String           @map("tournament_id")
  name              String
  sportType         String           @map("sport_type")
  gender            Gender
  format            TournamentFormat
  maxRegistrations  Int              @map("max_registrations")
  registrationPrice Decimal          @map("registration_price") @db.Decimal(10, 2)
  createdAt         DateTime         @default(now()) @map("created_at")

  tournament    Tournament               @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  registrations TournamentRegistration[]
  matches       Match[]

  @@map("tournament_categories")
}

model TournamentRegistration {
  id           String   @id @default(uuid())
  tournamentId String   @map("tournament_id")
  categoryId   String   @map("category_id")
  playerId     String   @map("player_id")
  partnerId    String?  @map("partner_id")
  status       String   @default("pending")
  paymentId    String?  @map("payment_id")
  registeredAt DateTime @default(now()) @map("registered_at")
  createdAt    DateTime @default(now()) @map("created_at")

  tournament Tournament         @relation(fields: [tournamentId], references: [id])
  category   TournamentCategory @relation(fields: [categoryId], references: [id])
  player     Player             @relation(fields: [playerId], references: [id])
  payment    Payment?           @relation(fields: [paymentId], references: [id])

  @@map("tournament_registrations")
}

model Match {
  id           String      @id @default(uuid())
  tournamentId String?     @map("tournament_id")
  categoryId   String?     @map("category_id")
  clubId       String      @map("club_id")
  courtId      String?     @map("court_id")
  round        String?
  matchNumber  Int?        @map("match_number")
  startTime    DateTime?   @map("start_time")
  status       MatchStatus @default(scheduled)
  score        Json?
  winnerId     String?     @map("winner_id")
  isWalkover   Boolean     @default(false) @map("is_walkover")
  notes        String?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  tournament   Tournament?         @relation(fields: [tournamentId], references: [id])
  category     TournamentCategory? @relation(fields: [categoryId], references: [id])
  court        Court?              @relation(fields: [courtId], references: [id])
  participants MatchParticipant[]

  @@index([tournamentId, status], name: "idx_matches_tournament_status")
  @@map("matches")
}

model MatchParticipant {
  id        String   @id @default(uuid())
  matchId   String   @map("match_id")
  playerId  String   @map("player_id")
  side      String
  partnerId String?  @map("partner_id")
  createdAt DateTime @default(now()) @map("created_at")

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])

  @@map("match_participants")
}

model Ranking {
  id               String      @id @default(uuid())
  clubId           String      @map("club_id")
  name             String
  sportType        String      @map("sport_type")
  category         String?
  type             RankingType @default(manual)
  isPublic         Boolean     @default(true) @map("is_public")
  seasonStart      DateTime?   @map("season_start") @db.Date
  seasonEnd        DateTime?   @map("season_end") @db.Date
  lastCalculatedAt DateTime?   @map("last_calculated_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  club    Club           @relation(fields: [clubId], references: [id])
  entries RankingEntry[]

  @@index([clubId], name: "idx_rankings_club")
  @@map("rankings")
}

model RankingEntry {
  id                String   @id @default(uuid())
  rankingId         String   @map("ranking_id")
  playerId          String   @map("player_id")
  position          Int
  previousPosition  Int?     @map("previous_position")
  points            Decimal  @db.Decimal(10, 2)
  tournamentsPlayed Int      @default(0) @map("tournaments_played")
  wins              Int      @default(0)
  losses            Int      @default(0)
  updatedAt         DateTime @updatedAt @map("updated_at")

  ranking Ranking @relation(fields: [rankingId], references: [id], onDelete: Cascade)
  player  Player  @relation(fields: [playerId], references: [id])

  @@unique([rankingId, playerId])
  @@index([rankingId, position], name: "idx_ranking_entries_position")
  @@map("ranking_entries")
}

model Payment {
  id                       String        @id @default(uuid())
  clubId                   String        @map("club_id")
  userId                   String        @map("user_id")
  bookingId                String?       @map("booking_id")
  subscriptionId           String?       @map("subscription_id")
  tournamentRegistrationId String?       @map("tournament_registration_id")
  classId                  String?       @map("class_id")
  description              String
  amount                   Decimal       @db.Decimal(10, 2)
  status                   PaymentStatus @default(pending)
  method                   String?
  dueDate                  DateTime      @map("due_date") @db.Date
  paidAt                   DateTime?     @map("paid_at")
  notes                    String?
  createdById              String        @map("created_by_id")
  createdAt                DateTime      @default(now()) @map("created_at")
  updatedAt                DateTime      @updatedAt @map("updated_at")

  club                    Club                     @relation(fields: [clubId], references: [id])
  user                    User                     @relation("UserPayments", fields: [userId], references: [id])
  booking                 Booking?                 @relation(fields: [bookingId], references: [id])
  class                   Class?                   @relation(fields: [classId], references: [id])
  createdBy               User                     @relation("PaymentCreator", fields: [createdById], references: [id])
  tournamentRegistrations TournamentRegistration[]

  @@index([clubId, status, dueDate], name: "idx_payments_club_status_due")
  @@index([userId], name: "idx_payments_user_id")
  @@map("payments")
}

model Plan {
  id                     String   @id @default(uuid())
  name                   String
  priceMonthly           Decimal  @map("price_monthly") @db.Decimal(10, 2)
  priceYearly            Decimal  @map("price_yearly") @db.Decimal(10, 2)
  maxCourts              Int      @map("max_courts")
  maxTeamMembers         Int      @map("max_team_members")
  maxTournamentsPerMonth Int      @map("max_tournaments_per_month")
  features               Json     @default("{}")
  isActive               Boolean  @default(true) @map("is_active")
  createdAt              DateTime @default(now()) @map("created_at")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                 String             @id @default(uuid())
  clubId             String             @unique @map("club_id")
  planId             String             @map("plan_id")
  status             SubscriptionStatus @default(trialing)
  currentPeriodStart DateTime           @map("current_period_start") @db.Date
  currentPeriodEnd   DateTime           @map("current_period_end") @db.Date
  trialEnd           DateTime?          @map("trial_end") @db.Date
  cancelledAt        DateTime?          @map("cancelled_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  club Club @relation(fields: [clubId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model Notification {
  id        String              @id @default(uuid())
  userId    String              @map("user_id")
  clubId    String?             @map("club_id")
  type      String
  title     String
  body      String
  data      Json?
  isRead    Boolean             @default(false) @map("is_read")
  readAt    DateTime?           @map("read_at")
  channel   NotificationChannel
  sentAt    DateTime?           @map("sent_at")
  createdAt DateTime            @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club? @relation(fields: [clubId], references: [id])

  @@index([userId, isRead], name: "idx_notifications_user_unread")
  @@map("notifications")
}

model Product {
  id          String   @id @default(uuid())
  clubId      String   @map("club_id")
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  stock       Int?
  category    String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  club       Club        @relation(fields: [clubId], references: [id])
  orderItems OrderItem[]

  @@map("products")
}

model Order {
  id        String   @id @default(uuid())
  clubId    String   @map("club_id")
  userId    String   @map("user_id")
  total     Decimal  @db.Decimal(10, 2)
  status    String   @default("pending")
  paymentId String?  @map("payment_id")
  createdAt DateTime @default(now()) @map("created_at")

  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  productId String   @map("product_id")
  quantity  Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model AuditLog {
  id         String   @id @default(uuid())
  clubId     String?  @map("club_id")
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  before     Json?
  after      Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  club Club? @relation(fields: [clubId], references: [id])
  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId], name: "idx_audit_logs_entity")
  @@index([clubId, createdAt], name: "idx_audit_logs_club_created")
  @@map("audit_logs")
}

model File {
  id           String   @id @default(uuid())
  uploadedById String   @map("uploaded_by_id")
  clubId       String?  @map("club_id")
  originalName String   @map("original_name")
  storageKey   String   @map("storage_key")
  url          String
  mimeType     String   @map("mime_type")
  sizeBytes    BigInt   @map("size_bytes")
  createdAt    DateTime @default(now()) @map("created_at")

  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@map("files")
}
