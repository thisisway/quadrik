    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "rimraf": "^5.0.10",
    "turbo": "^2.3.0",
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@9.15.9"
}
